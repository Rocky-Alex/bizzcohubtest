{
  "name": "bch-qc",
  "private": true,
  "version": "2.0.8",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.bizzco.bchqc",
    "productName": "BCH-QC",
    "artifactName": "BCH-QC Setup ${version}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "verifyUpdateCodeSignature": false,
      "signtoolOptions": {
        "certificateFile": "bizzco-cert.pfx",
        "certificatePassword": "bizzco123"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Rocky-Alex",
        "repo": "bizzcohubtest",
        "releaseType": "draft"
      }
    ],
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ]
  },
  "dependencies": {
    "electron-updater": "6.8.3"
  },
  "devDependencies": {
    "lucide-react": "0.475.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "42.3.3",
    "electron-builder": "25.1.8",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.12",
    "wait-on": "8.0.2"
  }
}
