{
    "project_name": "Bizz Co Hub Next.js App",
    "description": "A comprehensive Next.js application for inventory management, billing, and e-commerce for Bizz Co Hub.",
    "tech_stack": {
        "framework": "Next.js 14 (App Router), React 18",
        "language": "TypeScript",
        "database": "PostgreSQL (pg, @neondatabase/serverless)",
        "styling": "Tailwind CSS, Styled Components",
        "authentication": "NextAuth.js",
        "image_processing": "React Easy Crop, Browser Image Compression, ImageKit, @imgly/background-removal",
        "pdf_generation": "@react-pdf/renderer",
        "email": "Resend, Nodemailer, Imap-Simple"
    },
    "directory_structure": {
        "src/app": "Contains Next.js app router pages and API routes.",
        "src/components": "Reusable UI components.",
        "src/lib": "Core utilities, database connection (db.ts), email, and third-party integrations.",
        "src/types": "TypeScript interfaces and type definitions (e.g., index.ts).",
        "public": "Static assets like images and fonts."
    },
    "project_shapes_and_types": {
        "Product": {
            "id": "string | number",
            "productCode": "string",
            "name": "string",
            "brand": "string",
            "price": "number",
            "stock": "number",
            "category": "string",
            "specifications": "ProductSpecifications object (RAM, Processor, Storage, etc.)"
        },
        "DatabaseProduct": {
            "description": "Database representation of a product.",
            "fields": [
                "id",
                "product_code",
                "product_name",
                "base_price",
                "offer_price",
                "stock_quantity",
                "processor",
                "ram",
                "storage",
                "graphics_card",
                "condition_status"
            ]
        },
        "User": {
            "id": "number",
            "username": "string",
            "email": "string",
            "role": "string",
            "approval_status": "string"
        },
        "Invoice": {
            "id": "number",
            "invoice_no": "string",
            "customer_name": "string",
            "total_amount": "number",
            "status": "string",
            "created_date": "string"
        },
        "PurchaseLot": {
            "id": "number",
            "lot_no": "string",
            "supplier_name": "string",
            "total_items": "number",
            "total_cost": "number",
            "status": "string"
        }
    },
